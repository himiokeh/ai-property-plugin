# AI Property — optional API keys (copy to .env or export these in your shell)
# Both are OPTIONAL. evaluate-property and kv-buyer-strategy work without them.

# Google Maps — geocoding, MRT distances, nearby places.
# console.cloud.google.com → enable Geocoding API, Distance Matrix API, Places API (New)
GOOGLE_MAPS_API_KEY=

# Firecrawl — powers property-research (PropertyGuru scraping). firecrawl.dev (free 500/mo)
FIRECRAWL_API_KEY=
